# Default Hermes config baked into the template (agent-only).
# Copy/adapt during template build to ~/.hermes/config.yaml.
# NO product secrets here — use Worker / Nango for those.
#
# Tool surface is channel-agnostic: use platform_toolsets with a shared
# YAML anchor (*agent_tools → hermes-cli), not hermes-telegram. See
# config.yaml for the live list (telegram / whatsapp / cli / cron).

# model: set at runtime via Worker-provided env or proxy if needed

# Example tool posture (adjust when wiring real policy):
# Disable gateway platforms inside the sandbox — Worker owns channel delivery.
# platforms: {}

# Composio — official Hermes MCP shape (composio.dev/hermes).
# Multi-user: proxy URL + Bearer ${FROMDONNA_COMPOSIO_MCP_TOKEN} from bootstrap
# (never COMPOSIO_API_KEY in the sandbox). Live block is in config.yaml.
# mcp_servers:
#   composio:
#     url: "https://fromdonna-composio-proxy…/mcp"
#     headers:
#       Authorization: "Bearer ${FROMDONNA_COMPOSIO_MCP_TOKEN}"
#     connect_timeout: 60
#     timeout: 180
#     skip_preflight: true

agent:
